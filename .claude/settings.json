{
  "env": {
    "MACCABIPEDIA_UA_SCRIPT": "gamesbot"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(awk:*)",
      "Bash(column:*)",
      "Bash(du:*)",
      "Bash(jq:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git worktree:*)",
      "Bash(git ls-tree:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(bash .claude/scripts/*)",
      "Bash(chmod +x .claude/scripts/*)",
      "Bash(acli:*)",
      "Bash(open:*)",
      "Bash(diff:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(sed:*)",
      "Bash(host:*)",
      "Bash(curl:*)",
      "Bash(mkdir -p /tmp/maccabipedia/:*)",
      "Write(/tmp/maccabipedia/)",
      "Read(/tmp/maccabipedia/)",
      "mcp__trello__*",
      "mcp__youtube__*"
    ]
  }
}
